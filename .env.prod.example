# Production Environment Template
# Copy this to .env.prod and fill in your actual values

# Frontend Configuration
WEB_ROOT=/srv
API_HOST=backend
API_PORT=8080
PORT=80

# Backend Configuration
GO_ENV=production
DB_HOST=postgres
DB_PORT=5432
DB_NAME=darth_forge_prod
LOG_LEVEL=info

# Domain for Caddy HTTPS (CHANGE THIS!)
DOMAIN=yoursite.com

# Project Name
COMPOSE_PROJECT_NAME=darth-forge-prod

# Secrets (DO NOT commit .env.prod with real values!)
# DB_PASSWORD=your_secure_password_here
# JWT_SECRET=your_jwt_secret_here
# API_KEY=your_api_key_here
